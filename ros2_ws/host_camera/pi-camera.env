# Raspberry Pi camera defaults.
#
# This file is installed to /etc/default/pi-camera by install.sh.
# Edit the installed copy on the Pi host, then restart:
#   sudo systemctl restart pi-camera-feed

PI_CAMERA_DEVICE=/dev/video10
PI_CAMERA_VIDEO_NR=10
PI_CAMERA_CARD_LABEL="Pi Camera"

PI_CAMERA_WIDTH=640
PI_CAMERA_HEIGHT=480
PI_CAMERA_FPS=15
PI_CAMERA_PIXEL_FORMAT=YUYV

# First implementation target: rpicam-vid MJPEG into ffmpeg YUYV output.
# If hardware testing shows GStreamer is more stable, only the feed wrapper
# should need to change.
PI_CAMERA_PRODUCER=rpicam_ffmpeg_yuyv
